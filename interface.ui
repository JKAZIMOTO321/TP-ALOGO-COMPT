        <property name="styleSheet">
         <string notr="true">/* Style par défaut du bouton */
QPushButton {	
	background-color: rgb(55, 144, 138);
    color: white;
    border-radius: 4px;      /* C'est ici que l'arrondi se joue */
    border: 3px solid #52c3c5;
    padding: 5px;
    font-size: 16px;
}

/* Effet au survol de la souris (Hover) */
QPushButton:hover {
	background-color: #52c3c5;
	font-weight : bold;
}

/* Effet quand on clique (Pressed) */
QPushButton:pressed {
    background-color: blue;
    padding-left: 7px; /* Petit effet de mouvement */
    padding-top: 7px;
}background-color: rgb(85, 0, 255);
font: italic 15pt &quot;MS Sans Serif&quot;;
color: rgb(255, 255, 255);
border-color: rgb(255, 255, 255);</string>
